    {
      "parameters": {
        "jsCode": "try {\n    // 1. Recupera os dados brutos validados pelo nó anterior\n    const rawData = $item(0).$node[\"Compara Get Memory1\"].json[\"Redis2\"];\n\n    // 2. Valida e converte para Array (faz o parse caso o Redis tenha retornado uma string JSON)\n    const mensagensArray = Array.isArray(rawData) ? rawData : JSON.parse(rawData);\n\n    // 3. Concatena os elementos do array separando-os por um espaço\n    const mensagem_completa = mensagensArray.join(\" \");\n\n    // 4. Retorna a estrutura JSON padronizada para o n8n\n    return [{ \n        json: { \n            mensagem_completa: mensagem_completa \n        } \n    }];\n\n} catch (error) {\n    // 5. Tratamento de erro: evita que o fluxo quebre caso os dados sejam inválidos\n    return [{ \n        json: { \n            mensagem_completa: \"\",\n            log_erro: \"Falha ao processar dados do Redis: \" + error.message \n        } \n    }];\n}"
      },
      "id": "10a59ecb-aeb9-4b9c-a4b8-e4d27d9bde10",
